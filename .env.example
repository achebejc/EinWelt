# ─────────────────────────────────────────────────────────────────────────────
# OneWorld API — Environment Variables Template
# Copy this file to .env and fill in real values before running the application.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="OneWorld API"
APP_VERSION="1.0.0"
# Options: development | staging | production
ENVIRONMENT=development

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-me-generate-a-real-64-char-hex-secret
# JWT expiry in minutes (default 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Maximum request body size in bytes (default 1 MB)
MAX_REQUEST_SIZE=1048576

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/oneworld
# Connection pool settings (tune for your workload)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Default cache TTL in seconds
CACHE_TTL=300

# ── URLs ──────────────────────────────────────────────────────────────────────
# The URL your React Native / Expo frontend is served from (used for CORS)
FRONTEND_URL=http://localhost:19006
# The public base URL of this API (used in e-mail links)
APP_BASE_URL=http://localhost:8000

# ── SMTP (e-mail) ─────────────────────────────────────────────────────────────
# Leave blank to use the development stub (prints to stdout)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@oneworld.app
SMTP_USE_TLS=true

# ── Stripe ────────────────────────────────────────────────────────────────────
# Leave blank to disable billing endpoints
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Sentry (error tracking) ───────────────────────────────────────────────────
# Leave blank to disable Sentry
SENTRY_DSN=https://...@sentry.io/...

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Set to true in production for JSON-structured logs
LOG_JSON=false

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Leave blank to disable AI utility endpoints
OPENAI_API_KEY=sk-...

# ── Owner bootstrap ───────────────────────────────────────────────────────────
# These credentials are used to seed the initial owner account on first startup.
# Change them before deploying to production.
OWNER_EMAIL=ceo@oneworld.app
OWNER_PASSWORD=ChangeThisOwnerPassword123!
OWNER_FULL_NAME=Jessica Chekwube Achebe
